class Solution:
    def partition(self, s: str) -> list[list[str]]:
        result = []
        n = len(s)
        
        def is_palindrome(sub_s: str) -> bool:
            return sub_s == sub_s[::-1]

        def backtrack(idx: int, curr_path: list[str]):
            if idx == n:
                result.append(list(curr_path))
                return
            
            for i in range(idx, n):
                substring = s[idx : i + 1]
                
                if is_palindrome(substring):
                    curr_path.append(substring)
                    backtrack(i + 1, curr_path)
                    curr_path.pop()
        backtrack(0, [])
        return result
