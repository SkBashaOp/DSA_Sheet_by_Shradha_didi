class Solution:
    def maxCoins(self, nums: List[int]) -> int:
        n=len(nums)
        arr=[1]+nums+[1]
        memo={}
        def solve(left,right):
            if left>right:
                return 0
            key=(left,right)
            if key in memo:
                return memo[key]
            best = 0
            for k in range(left, right + 1):
                coins = arr[left - 1] * arr[k] * arr[right + 1]
                coins += solve(left, k - 1)
                coins += solve(k + 1, right)
                if coins > best:
                    best = coins
            memo[key] = best
            return best

        return solve(1, n)
