class Solution {
public:
    bool isSafe(vector<string> &board,int row,int col,int n){
        //horizontal
        for(int j=0;j<n;j++){
            if(board[row][j]=='Q'){
                return false;
            }
        }
        //vertically
        for(int i=0;i<n;i++){
            if(board[i][col]=='Q'){
                return false;
            }
        }
        //left diagonal
        for(int i=row,j=col; i>=0 && j>=0; i--,j--){
            if(board[i][j]=='Q'){
                return false;
            }
        }
        //right diagonal
        for(int i=row,j=col; i>=0 && j<n; i--,j++){
            if(board[i][j]=='Q'){
                return false;
            }
        }
        return true;
    }
    void nQueens(vector<string> &board,int row,int n,vector<vector<string>> &ans){
        if(row==n){
            ans.push_back({board});
            return;
        }
        for(int j=0;j<n;j++){
            if(isSafe(board,row,j,n)){
                board[row][j]='Q';
                nQueens(board,row+1,n,ans);
                board[row][j]='.';
            }
        }
    }
    vector<vector<string>> solveNQueens(int n) {
        vector<string> board(n,string(n,'.'));
        vector<vector<string>> ans;
        nQueens(board,0,n,ans);
        return ans;
    }
};


1. The Inner Part: string(n, '.')This is a specific C++ string constructor. It says: "Create a string that is n characters long, and fill every spot with a period .."If $n = 4$, this creates the string .....2. The Outer Part: vector<string> board(n, ...)This is the vector constructor. It says: "Create a vector containing n elements, and initialize each element with the value provided."Since the "value provided" is our string from step 1, it places that string into every row of the vector.Visualizing the ResultIf we assume $n = 4$, here is how that single line builds your board:IndexValue (String)board[0]"...."board[1]"...."board[2]"...."board[3]"...."
