class Solution {
public:
    void getAllCombinations(vector<int>& arr, int start, int tar,
                            vector<vector<int>>& ans,
                            vector<int>& combin) {
        
        if (tar == 0) {
            ans.push_back(combin);
            return;
        }

        for (int i = start; i < arr.size(); i++) {

            // ✅ Skip duplicates at same level
            //If two same numbers appear at SAME LEVEL → skip duplicates
            //If they appear in DIFFERENT LEVELS → allow them
            if (i > start && arr[i] == arr[i - 1])
                continue;

            if (arr[i] > tar)
                break;

            combin.push_back(arr[i]);
            getAllCombinations(arr, i + 1, tar - arr[i], ans, combin);
            combin.pop_back();
        }
    }

    vector<vector<int>> combinationSum2(vector<int>& arr, int target) {
        sort(arr.begin(), arr.end());
        vector<vector<int>> ans;
        vector<int> combin;
        getAllCombinations(arr, 0, target, ans, combin);
        return ans;
    }
};
