from collections import defaultdict
class Solution:
    def majorityElement(self, nums: List[int]) -> int:
        n=len(nums)
        freq=defaultdict(int)
        for num in nums:
            freq[num]+=1
        for k,v in freq.items():
            if v>n//2:
                return k    

class Solution:
    def majorityElement(self, nums: List[int]) -> int:
        nums.sort()
        return nums[len(nums) // 2]
        
