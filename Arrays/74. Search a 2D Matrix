class Solution:
    def searchInRow(self, matrix, target, row):
        n = len(matrix[0])
        st, end = 0, n - 1
        
        while st <= end:
            mid = st + (end - st) // 2
            if target == matrix[row][mid]:
                return True
            elif target > matrix[row][mid]:
                st = mid + 1
            else:
                end = mid - 1
        
        return False

    def searchMatrix(self, matrix, target):
        if not matrix or not matrix[0]:
            return False
            
        m = len(matrix)
        n = len(matrix[0])
        startRow, endRow = 0, m - 1
        
        while startRow <= endRow:
            midRow = startRow + (endRow - startRow) // 2
            
            if target >= matrix[midRow][0] and target <= matrix[midRow][n-1]:
                return self.searchInRow(matrix, target, midRow)
            elif target >= matrix[midRow][n-1]:
                startRow = midRow + 1
            else:
                endRow = midRow - 1
                
        return False
