//rows are overlapping in range

class Solution:
    def searchMatrix(self, mat, target):
        m = len(mat)
        n = len(mat[0])
        
        r = 0
        c = n - 1
        
        while r < m and c >= 0:
            if target == mat[r][c]:
                return True
            elif target < mat[r][c]:
                c -= 1
            else:
                r += 1
                
        return False
