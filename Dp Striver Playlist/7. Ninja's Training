from typing import *
def f(n,points,last,dp):
    if n==0:
        maxi=0
        for i in range(3):
            if i!=last:
                maxi=max(maxi,points[0][i])
        return maxi 
    if dp[n][last] != -1:
        return dp[n][last]    
    maxi=0
    for i in range(3):
        if i!=last:
            point=points[n][i] + f(n-1,points,i,dp)  
            maxi=max(maxi,point)
    dp[n][last]=maxi
    return dp[n][last]             

def ninjaTraining(n: int, points: List[List[int]]) -> int:
    dp=[[-1 for _ in range(4)] for _ in range(n)]
    return f(n-1,points,3,dp)


