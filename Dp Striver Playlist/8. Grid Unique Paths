##space opti
class Solution:
    def uniquePaths(self, m: int, n: int) -> int:
        prev=[1]*n       
        for i in range(m):
            temp=[1]*n
            for j in range(n):
                if i == 0 and j == 0:
                    temp[j] = 1
                else:
                    up = prev[j] if i > 0 else 0
                    left = temp[j-1] if j > 0 else 0
                    temp[j] = up + left 
            prev=temp
        return prev[n-1]      
