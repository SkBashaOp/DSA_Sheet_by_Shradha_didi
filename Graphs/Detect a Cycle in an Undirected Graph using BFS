from collections import deque

class Solution:
    def detect(self, src, adj, vis):
        vis[src] = True
        queue = deque([(src, -1)])
        
        while queue:
            node, parent = queue.popleft()
            
            for adjacent_node in adj[node]:
                if not vis[adjacent_node]:
                    vis[adjacent_node] = True
                    queue.append((adjacent_node, node))
                elif parent != adjacent_node:
                    return True
        return False

    def isCycle(self, V, adj):
        vis = [False] * V
        for i in range(V):
            if not vis[i]:
                if self.detect(i, adj, vis):
                    return True
        return False

if __name__ == "__main__":
    adj = [[], [2], [1, 3], [2]]
    V = 4
    obj = Solution()
    ans = obj.isCycle(V, adj)
    print(1 if ans else 0)
