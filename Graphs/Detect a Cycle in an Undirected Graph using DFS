class Solution:
    def dfs(self, node, parent, adj, visited):
        visited[node] = True

        for neighbor in adj[node]:
            if not visited[neighbor]:
                if self.dfs(neighbor, node, adj, visited):
                    return True
            elif neighbor != parent:
                return True

        return False

    def isCycle(self, V, adj):
        visited = [False] * V

        for i in range(V):
            if not visited[i]:
                if self.dfs(i, -1, adj, visited):
                    return True
        return False
