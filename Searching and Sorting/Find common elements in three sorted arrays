from collections import defaultdict
class Solution:
    def commonElements(self, arr1, arr2, arr3):
        #Code Here
        count=defaultdict(int)
        arr=[]
        for ele in set(arr1):
            count[ele]+=1
        for ele in set(arr2):
            count[ele]+=1
        for ele in set(arr3):
            count[ele]+=1 
        for k,v in count.items():
            if v==3:
                arr.append(k)   
        arr.sort()        
        return arr if arr else [-1]
