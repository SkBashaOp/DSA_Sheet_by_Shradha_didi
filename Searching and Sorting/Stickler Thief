class Solution:
    def maxLootRec(self, arr, n, dp):
        if n <= 0:
            return 0
        
        if n == 1:
            return arr[0]
        
        if dp[n] != -1:
            return dp[n]

        pick = arr[n - 1] + self.maxLootRec(arr, n - 2, dp)
        notPick = self.maxLootRec(arr, n - 1, dp)

        dp[n] = max(pick, notPick)
        return dp[n]

    def findMaxSum(self, arr):
        n = len(arr)
        dp = [-1] * (n + 1)
        return self.maxLootRec(arr, n, dp)


