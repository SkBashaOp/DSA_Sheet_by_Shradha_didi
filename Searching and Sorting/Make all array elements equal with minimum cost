class Solution:
    def minCost(self, arr):
        n = len(arr)
        
        # Step 1: Sort
        arr.sort()
        
        # Step 2: Find median
        median = arr[n // 2]
        
        # Step 3: Calculate cost
        total_cost = 0
        for num in arr:
            total_cost += abs(num - median)
        
        return total_cost
