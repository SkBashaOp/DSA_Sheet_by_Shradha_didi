class Solution:
    def findSubarray(self, arr):
        n = len(arr)
        arr1=[]

        for i in range(n):
            current_sum = 0
            for j in range(i, n):
                current_sum += arr[j]
    
                if current_sum == 0:
                    arr1.append(arr[i:j+1])
        return len(arr1)            

calculate prefix sums if pre1==pre2 then there is subarray with sum==0
from collections import defaultdict
class Solution:
    def findSubarray(self, arr):
        n = len(arr)
        freq=defaultdict(int)
        freq[0] = 1
        prefix_sum = 0
        count=0
        
        for num in arr:
            prefix_sum+=num
            
            count+=freq[prefix_sum]
            
            freq[prefix_sum]+=1
        return count    
            
            
                       
