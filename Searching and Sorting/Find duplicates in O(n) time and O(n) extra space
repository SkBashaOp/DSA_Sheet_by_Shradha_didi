from collections import defaultdict

def find_duplicates(arr): 
    freq_map = defaultdict(int) //freqMap = {}
    result = []

    for num in arr:           //for num in arr: freqMap[num] = freqMap.get(num, 0) + 1
        freq_map[num] += 1

    for key, count in freq_map.items():
        if count > 1:
            result.append(key)

    if not result:
        return [-1]

    return result

arr = [1, 6, 5, 2, 3, 3, 2]
duplicates = find_duplicates(arr)
print(*(duplicates))
