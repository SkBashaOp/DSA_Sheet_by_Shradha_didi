class Solution:
    def mergeArrays(self, a, b):
        m=len(a)
        n=len(b)
        i=m-1
        j=0
        
        while i>=0 and j<n:
            if a[i]>b[j]:
                a[i],b[j]=b[j],a[i]
                i=i-1
                j=j+1
            else:
                break
        a.sort()
        b.sort()
        return a+b
        
