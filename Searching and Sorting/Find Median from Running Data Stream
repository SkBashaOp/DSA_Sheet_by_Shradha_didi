import heapq

class Solution:
    def getMedians(self, arr):
        max_heap = []  # for smaller half (as negative values)
        min_heap = []  # for larger half
        
        result = []
        
        for num in arr:
            
            # Step 1: Add number
            heapq.heappush(max_heap, -num)
            
            # Step 2: Balance heaps (move largest from max_heap to min_heap)
            heapq.heappush(min_heap, -heapq.heappop(max_heap))
            
            # Step 3: Ensure size property
            if len(min_heap) > len(max_heap):
                heapq.heappush(max_heap, -heapq.heappop(min_heap))
            
            # Step 4: Find median
            if len(max_heap) > len(min_heap):
                result.append(-max_heap[0])
            else:
                result.append((-max_heap[0] + min_heap[0]) / 2)
        
        return result
        
