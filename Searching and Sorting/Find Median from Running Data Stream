class Solution:
    def getMedian(self, arr):
        arr.sort()
        n = len(arr)
        
        if n % 2 == 1:
            return arr[n // 2]
        else:
            return (arr[n//2 - 1] + arr[n//2]) / 2

class Solution:
    def getMedian(self, arr):
        result = []
        temp = []
        
        for num in arr:
            temp.append(num)
            temp.sort()
            n = len(temp)
            
            if n % 2 == 1:
                median = temp[n // 2]
            else:
                median = (temp[n//2 - 1] + temp[n//2]) / 2
            
            result.append(float(median))


import heapq

class Solution:
    def getMedian(self, arr):
        
        leftMaxHeap = []  # max heap (store negatives)
        rightMinHeap = [] # min heap
        
        result = []
        
        for num in arr:
            
            # Insert into correct heap
            if not leftMaxHeap or num < -leftMaxHeap[0]:
                heapq.heappush(leftMaxHeap, -num)
            else:
                heapq.heappush(rightMinHeap, num)
            
            # Balance sizes
            if abs(len(leftMaxHeap) - len(rightMinHeap)) > 1:
                heapq.heappush(rightMinHeap, -heapq.heappop(leftMaxHeap))
            
            elif len(leftMaxHeap) < len(rightMinHeap):
                heapq.heappush(leftMaxHeap, -heapq.heappop(rightMinHeap))
            
            # Calculate current median
            if len(leftMaxHeap) == len(rightMinHeap):
                median = (-leftMaxHeap[0] + rightMinHeap[0]) / 2
            else:
                median = -leftMaxHeap[0]
            
            result.append(float(median))
        
        return result


import heapq

class MedianFinder:

    def __init__(self):
        # leftMaxHeap (max heap) → store negatives
        self.leftMaxHeap = []
        
        # rightMinHeap (min heap)
        self.rightMinHeap = []

    def addNum(self, num: int) -> None:
        
        # Step 1: Insert into correct heap
        if not self.leftMaxHeap or num < -self.leftMaxHeap[0]:
            heapq.heappush(self.leftMaxHeap, -num)
        else:
            heapq.heappush(self.rightMinHeap, num)

        # Step 2: Balance heaps
        
        # If size difference > 1
        if abs(len(self.leftMaxHeap) - len(self.rightMinHeap)) > 1:
            heapq.heappush(self.rightMinHeap, -heapq.heappop(self.leftMaxHeap))
        
        # If right side bigger
        elif len(self.leftMaxHeap) < len(self.rightMinHeap):
            heapq.heappush(self.leftMaxHeap, -heapq.heappop(self.rightMinHeap))

    def findMedian(self) -> float:
        
        if len(self.leftMaxHeap) == len(self.rightMinHeap):
            return (-self.leftMaxHeap[0] + self.rightMinHeap[0]) / 2.0
        
        return float(-self.leftMaxHeap[0])
